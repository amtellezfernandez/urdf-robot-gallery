{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "importUrl", "runtimeTargets", "updatedAt"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      },
      "title": { "type": "string", "minLength": 1 },
      "importUrl": { "type": "string", "minLength": 1 },
      "description": { "type": "string" },
      "owner": { "type": "string" },
      "tags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "uniqueItems": true
      },
      "runtimeTargets": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "minItems": 1,
        "uniqueItems": true
      },
      "updatedAt": { "type": "string", "minLength": 1 }
    },
    "additionalProperties": false
  }
}

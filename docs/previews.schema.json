{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "generatedAt", "previews"],
  "properties": {
    "version": { "type": "number" },
    "generatedAt": { "type": "string" },
    "previews": {
      "type": "array",
      "items": { "$ref": "#/$defs/preview" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "preview": {
      "type": "object",
      "required": ["repoKey", "fileBase"],
      "properties": {
        "repoKey": { "type": "string" },
        "fileBase": { "type": "string" },
        "webp": { "type": "string" },
        "webm": { "type": "string" },
        "mp4": { "type": "string" },
        "png": { "type": "string" },
        "sourceType": {
          "type": "string",
          "enum": ["urdf", "xacro", "urdf.xacro"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "macroTags": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Arms",
              "Bipeds",
              "Dual Arms",
              "Drones",
              "Educational",
              "End Effectors",
              "Humanoids",
              "Mobile Manipulators",
              "Quadrupeds",
              "Wheeled",
              "Other"
            ]
          },
          "uniqueItems": true
        },
        "meshCount": { "type": "integer", "minimum": 0 },
        "linkCount": { "type": "integer", "minimum": 0 },
        "jointCount": { "type": "integer", "minimum": 0 },
        "armCount": { "type": "integer", "minimum": 0 },
        "legCount": { "type": "integer", "minimum": 0 },
        "wheelCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
